{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Profile",
  "type": "object",
  "description": "Polkadot/Substrate profile entity",
  "properties": {
    "ss58address": {
      "type": "string",
      "description": "The SS58 address of the profile (primary key)",
      "pattern": "^5[A-HJ-NP-Z1-9]{32,34}$"
    },
    "nickname": {
      "type": "string",
      "description": "Optional unique nickname for the profile",
      "minLength": 1,
      "maxLength": 64
    },
    "bio": {
      "type": "string",
      "description": "Optional bio/description",
      "maxLength": 1000
    },
    "profilePicture": {
      "type": "string",
      "format": "uri",
      "description": "URL to the profile picture"
    },
    "x25519Key": {
      "type": "string",
      "description": "Optional x25519 public key (hex-encoded)",
      "pattern": "^(0x)?[0-9a-fA-F]{64}$"
    }
  },
  "required": ["ss58address"]
}
